// constants won't change const int buttonPin = 2; // pushbutton pin const int relayPin = 4; // relay control pin

// variable will change int buttonState = 0; // stores pushbutton status

void setup() { // set relay pin as output pinMode(relayPin, OUTPUT);

// set button pin as input pinMode(buttonPin, INPUT);

// make sure relay starts off digitalWrite(relayPin, LOW); }

void loop() { // read the pushbutton state buttonState = digitalRead(buttonPin);

// if button is pressed, turn relay on if (buttonState == HIGH) { digitalWrite(relayPin, HIGH); } else { digitalWrite(relayPin, LOW); } }
